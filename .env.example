# Copy this file to ".env" in the same folder as docker-compose.yml
# and fill in your real values. The ".env" file should NOT be
# committed to git (it's already in .gitignore).

# MySQL root password (used by both mysql and app containers)
MYSQL_ROOT_PASSWORD=rootpass

# Gmail SMTP credentials for sending reminder emails
# See: https://myaccount.google.com/apppasswords
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_16_char_app_password
